# Copy this file to .env and fill in the values before running docker compose.
# .env is intentionally excluded from version control (see .gitignore).

# Public base URL of this backend, as seen by PhaseMirror-HQ (no trailing slash).
# Example: https://api.yourdomain.com
AIISTECH_WEBHOOK_BASE_URL=https://your-backend-host

# Bearer token used to authenticate webhook requests with PhaseMirror-HQ.
# Generate a strong secret: openssl rand -hex 32
AIISTECH_WEBHOOK_TOKEN=generate-with-openssl-rand-hex-32

# Admin API key for protected admin endpoints:
#   GET /metrics        — expvar process metrics (JSON)
#   GET /debug/vars     — alias for /metrics
#   /webhooks/dlq/*     — DLQ management
#   /webhooks/subscriptions/* — subscription management
#
# When this variable is unset, /metrics and /debug/vars are NOT mounted (404).
# The DLQ and subscription routes are still accessible but a startup WARN is logged.
#
# Generate a strong key and keep it in your secrets manager — do NOT commit it:
#   openssl rand -hex 32
#
# In production, inject this via:
#   - GitHub Actions secrets  → ${{ secrets.AIISTECH_ADMIN_API_KEY }}
#   - Docker secrets          → docker secret create aiistech_admin_key <file>
#   - Kubernetes secrets      → kubectl create secret generic aiistech --from-literal=admin-key=<value>
AIISTECH_ADMIN_API_KEY=generate-with-openssl-rand-hex-32
